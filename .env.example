# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to git!

# Required: Your Argo Workflows bearer token
export ARGO_BEARER_TOKEN=ey...
export ARGO_API_URL=https://workflows.argocd.paidmedia.tda.link/api/v1/workflows/default
export S3_BUCKET=datalake-argo-reports

# Optional: Override defaults
# ARGO_NAMESPACE=default
# ARGO_WORKFLOW_LIMIT=1000
# S3_PREFIX=argo-reports/
# AWS_REGION=eu-central-1